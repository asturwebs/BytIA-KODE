# Structured Chain-of-Thought: GOAL / APPROACH / EDGE
# Compact 3-field plan for short coding tasks.
# Each rule MUST be on a single line (llama.cpp GBNF parser limitation).
# After </think>, code is unconstrained (all printable ASCII).

root ::= think code
think ::= "<think>\n" "GOAL: " line "APPROACH: " line "EDGE: " line "</think>\n\n"
line ::= [^\n]+ "\n"
code ::= [\x09\x0A\x0D\x20-\x7E]+
