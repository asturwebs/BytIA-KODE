# Structured Chain-of-Thought: GOAL / STATE / ALGO / EDGE / VERIFY
# Richer 5-field plan for harder coding tasks (LiveCodeBench style).
# Each rule MUST be on a single line (llama.cpp GBNF parser limitation).
# After </think>, code is unconstrained (all printable ASCII).

root ::= think code
think ::= "<think>\n" "GOAL: " line "STATE: " line "ALGO: " line "EDGE: " line "VERIFY: " line "</think>\n\n"
line ::= [^\n]+ "\n"
code ::= [\x09\x0A\x0D\x20-\x7E]+
