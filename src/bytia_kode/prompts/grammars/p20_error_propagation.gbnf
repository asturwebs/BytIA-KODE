# BytIA P20: Error Propagation Protocol
# Structured error reporting — exact error, root cause, action taken, severity.
# No embellishment. No simulated success. No blind retry cascades.
# Each rule MUST be on a single line.

root ::= think code
think ::= "<think>\n" "ERR: " line "WHY: " cause "DO: " action "SEV: " severity "</think>\n\n"
cause ::= "TIMEOUT" | "HTTP" | "PARSE" | "EMPTY" | "TOOL" | "UNKNOWN"
action ::= "REPORT" | "ASK" | "BLOCK"
severity ::= "LOW" | "MED" | "HIGH" | "CRIT"
line ::= [^\n]+ "\n"
code ::= [\x09\x0A\x0D\x20-\x7E]+
