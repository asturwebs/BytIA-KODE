# Provider - llama.cpp Router (single port, multi-modelo)
PROVIDER_BASE_URL=http://localhost:8080/v1
PROVIDER_API_KEY=not-needed
PROVIDER_MODEL=auto

# Fallback provider (cloud API)
FALLBACK_BASE_URL=
FALLBACK_API_KEY=
FALLBACK_MODEL=

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

# Local models (Ollama)
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL=gemma4:26b

# General
LOG_LEVEL=INFO
DATA_DIR=~/.bytia-kode

# Sandbox - extra binaries (comma-separated, added to default allowlist)
EXTRA_BINARIES=

# DeepSeek (V4 flash/pro)
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Grammar (Structured CoT via GBNF)
# Solo aplica cuando el provider lo soporta (llama.cpp localhost:8080).
# Se desactiva automáticamente cuando hay tool calls.
# Gramáticas disponibles en src/bytia_kode/prompts/grammars/
GRAMMAR_MODE=off
GRAMMAR_FILE=
