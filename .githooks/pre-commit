#!/usr/bin/env bash
set -euo pipefail

if [ -x ".venv/bin/python" ]; then
  PYTHON_BIN=".venv/bin/python"
elif command -v python3 >/dev/null 2>&1; then
  PYTHON_BIN="python3"
else
  PYTHON_BIN="python"
fi

"$PYTHON_BIN" scripts/validate_metadata.py
"$PYTHON_BIN" scripts/check_secrets.py
"$PYTHON_BIN" -m pytest -q
